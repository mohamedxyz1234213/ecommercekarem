NODE_ENV=development
PORT=5000
# Bind address: 0.0.0.0 = all interfaces (default), so phones on Wi‑Fi can reach the API.
# HOST=0.0.0.0
# Production lockdown: set NODE_ENV=production and do not set CORS_ALLOW_ALL.
# Emergency wide CORS (not recommended): CORS_ALLOW_ALL=true

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# JWT — use a long, random secret (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_with_a_long_random_secret

# Session
SESSION_SECRET=your_session_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password

# Admin Email (receives order notifications)
ADMIN_EMAIL=admin@example.com

# Cloudinary (persistent image storage for Vercel/serverless)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URLs (used for redirects / OAuth; add your LAN URL if needed)
# ── Deployment (Vercel) ──────────────────────────────────────────────────────
# 1. Deploy the backend first and note its Vercel URL
#    (e.g. https://ecommercekarem-backend.vercel.app).
# 2. In frontend/vercel.json AND admin/vercel.json replace the string
#    "YOUR_BACKEND_DOMAIN" with that URL in both /api and /uploads rewrites.
#    This ensures the browser only ever talks to the same domain as the frontend
#    and the backend URL is never exposed in the compiled JS bundle or DevTools.
# 3. Do NOT set VITE_API_URL in Vercel environment variables for the frontend /
#    admin projects — leave it unset so the proxy rewrites are used instead.
#    (Setting VITE_API_URL would embed the backend URL back into the bundle.)
CLIENT_URL=http://localhost:5174
ADMIN_URL=http://localhost:5173
# Optional extra origins (comma-separated), e.g. https://vybe.vercel.app,https://vybeadmin.vercel.app
# CORS_ALLOWED_ORIGINS=
# Optional for Vercel previews: allow any *.vercel.app origin
# CORS_ALLOW_VERCEL_PREVIEWS=false
# Phone / LAN: frontend & admin default the API to the same host at VITE_API_PORT.
# Ensure the backend listens on 0.0.0.0 (default).
# Optional: override port if API is not on 5000 (dev / LAN only):
# VITE_API_PORT=5000

