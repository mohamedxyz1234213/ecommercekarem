NODE_ENV=development
PORT=5000
# Bind address: 0.0.0.0 = all interfaces (default), so phones on Wi‑Fi can reach the API.
# HOST=0.0.0.0
# Production lockdown: set NODE_ENV=production and do not set CORS_ALLOW_ALL.
# Emergency wide CORS (not recommended): CORS_ALLOW_ALL=true

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# JWT — use a long, random secret (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_with_a_long_random_secret

# Session
SESSION_SECRET=your_session_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password

# Admin Email (receives order notifications)
ADMIN_EMAIL=admin@example.com

# Cloudinary (persistent image storage for Vercel/serverless)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URLs (used for redirects / OAuth; add your LAN URL if needed)
CLIENT_URL=http://localhost:5174
ADMIN_URL=http://localhost:5173
# Optional extra origins (comma-separated), e.g. https://vybe.vercel.app,https://vybeadmin.vercel.app
# CORS_ALLOWED_ORIGINS=
# Optional for Vercel previews: allow any *.vercel.app origin
# CORS_ALLOW_VERCEL_PREVIEWS=false
# Phone / LAN: frontend & admin now default the API to the same host as the page
# (e.g. http://192.168.x.x:5000/api). Ensure the backend listens on 0.0.0.0 (default).
# Optional: VITE_API_PORT if the API is not on 5000. Override API host on desktop only:
# VITE_API_URL=http://localhost:5000/api

